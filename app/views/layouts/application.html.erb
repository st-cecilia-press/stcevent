<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= # stylesheet_link_tag "/scripts/scripts.css" 
    %>
    <%= stylesheet_link_tag "/styles/styles.css" %>
    <%= javascript_include_tag "/scripts/scripts.js" %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

  </head>

  <body>
    <div class="container">
      <div class="d-none d-md-block text-center">
        <h1 class="display-1 text-center"><%= @event.title %></h1>
        <div class="border-top border-bottom border-5 border-dark" style="background-color: #f2ead6;">
        <%= image_tag("banner.png")%>
        </div>
        </div>
        <%= render "menu" %>
    </div>

    <main class="container" role="main">
      <%= yield %>
    </main>
  </body>
</html>
